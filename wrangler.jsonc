{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "iamon",
  "compatibility_date": "2026-03-27",
  "main": "./dist/_worker.js/index.js",
  "compatibility_flags": [
    "nodejs_compat",
    "global_fetch_strictly_public"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "observability": {
    "enabled": true
  }
}
