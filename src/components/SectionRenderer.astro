---
const { section, locale = "en" } = Astro.props;

const isZh = locale === "zh";
const actionLabel = isZh ? "查看" : "Open";
const bookingCtaLabel = isZh ? "预约一次交流" : "Book a chat";
const bookingOpensLabel = isZh ? "将打开 Calendly" : "Opens Calendly";

const sectionCopy = {
  pathways: isZh
    ? {
        eyebrow: "从这里开始",
        heading: "先选最适合你的入口",
        intro: "如果访问者带着明确目标进入网站，这几条入口通常会比从首页慢慢找更高效。",
        openLabel: "查看",
      }
    : {
        eyebrow: "Start here",
        heading: "Choose the shortest route into the site",
        intro: "If a visitor arrives with a specific goal, these entry points usually work better than making them browse from the top.",
        openLabel: "Open",
      },
  proof: isZh
    ? {
        eyebrow: "重点证明",
        heading: "先看证据，再看主张",
        intro: "这几个入口最适合快速判断你的工作背景、表达方式和可信度。",
        openLabel: "查看",
      }
    : {
        eyebrow: "Selected proof",
        heading: "See the work before the claims",
        intro: "These are the fastest routes into the background, working style, and likely contribution.",
        openLabel: "Open",
      },
  writing: isZh
    ? {
        eyebrow: "最新文章",
        heading: "用文章补充工作方式",
        intro: "这部分适合放更完整的文章、说明和思考，让别人理解你如何判断、表达和组织复杂信息。",
        openLabel: "查看",
      }
    : {
        eyebrow: "Recent writing",
        heading: "Use the writing to understand the thinking",
        intro: "This is where longer posts, notes, and explanations help people understand how you work, explain, and make decisions.",
        openLabel: "Open",
      },
  topics: isZh
    ? {
        eyebrow: "工作主题",
        heading: "我持续在做的几类事情",
        intro: "这些主题贯穿了我的工作、项目和长期兴趣，也是我最希望继续深化的方向。",
      }
    : {
        eyebrow: "Focus areas",
        heading: "What I work across",
        intro: "These themes show up repeatedly across roles, projects, and the conversations where this site is most useful.",
      },
};

const copy = {
  ...(sectionCopy[section.type] ?? {}),
  eyebrow: section.eyebrow ?? sectionCopy[section.type]?.eyebrow,
  heading: section.heading ?? sectionCopy[section.type]?.heading,
  intro: section.intro ?? sectionCopy[section.type]?.intro,
};
---
{(copy.heading || copy.intro || copy.eyebrow) && (
  <section class="section">
    <div class="section-head">
      {copy.eyebrow && <p class="eyebrow">{copy.eyebrow}</p>}
      {copy.heading && <h2 class="section-title">{copy.heading}</h2>}
      {copy.intro && <p class="section-copy">{copy.intro}</p>}
    </div>

    <div class="grid" style="margin-top:0;">
      {section.type === "topics" || section.type === "cards" ? (
        section.items.map((card) => (
          <article class={`card ${card.layout ?? "third"}`.trim()}>
            <p class="kicker">{card.title}</p>
            <p class="card-copy">{card.text}</p>
          </article>
        ))
      ) : section.type === "link-cards" ? (
        section.items.map((card) => (
          <a
            class={`card ${card.layout ?? "third"}`.trim()}
            href={card.href}
            target={card.external ? "_blank" : undefined}
            rel={card.external ? "noreferrer" : undefined}
            download={card.download ? true : undefined}
          >
            <p class="eyebrow" style="margin-bottom:10px;">{card.label}</p>
            {card.meta && <p class="small" style="margin-bottom:10px;">{card.meta}</p>}
            <p class="card-title">{card.title}</p>
            <p class="card-copy">{card.summary}</p>
            <p class="small" style="margin-top:16px;">{card.actionLabel ?? actionLabel}</p>
          </a>
        ))
      ) : section.type === "booking-options" ? (
        section.items.map((option) => (
          <section class="card">
            <p class="eyebrow" style="margin-bottom:10px;">{option.label ?? (isZh ? "形式" : "Format")}</p>
            <p class="card-title">{option.name}</p>
            {option.duration && <p class="small" style="margin-top:10px;">{option.duration}</p>}
            <p class="card-copy">{option.teaser}</p>
            <div class="cta-row">
              <a class="cta" href={option.url} target="_blank" rel="noreferrer">{option.ctaLabel ?? bookingCtaLabel}</a>
            </div>
            <p class="small" style="margin-top:12px;">{option.opensLabel ?? bookingOpensLabel}</p>
          </section>
        ))
      ) : section.type === "faq" ? (
        <div class="faq-list">
          {section.items.map((item) => (
            <article class="card faq-item">
              <p class="faq-question">{item.question}</p>
              <p class="card-copy">{item.answer}</p>
            </article>
          ))}
        </div>
      ) : (
        section.items.map((card) => (
          <a class={`card ${card.layout ?? "half"}`.trim()} href={card.href}>
            <p class="eyebrow" style="margin-bottom:10px;">{card.label}</p>
            {card.meta && <p class="small" style="margin-bottom:10px;">{card.meta}</p>}
            <p class="card-title">{card.title}</p>
            <p class="card-copy">{card.summary}</p>
            {"openLabel" in copy && <p class="small" style="margin-top:16px;">{copy.openLabel}</p>}
          </a>
        ))
      )}
    </div>
  </section>
)}
