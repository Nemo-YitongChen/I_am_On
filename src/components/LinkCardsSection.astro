---
import SectionRenderer from "./SectionRenderer.astro";
import { buildLinkCardSection } from "../lib/sections.js";

const { eyebrow, title, intro, cards = [], locale = "en" } = Astro.props;
const [section] = buildLinkCardSection({
  eyebrow,
  heading: title,
  intro,
  items: cards,
});
---
{section && <SectionRenderer section={section} locale={locale} />}
