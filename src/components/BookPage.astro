---
import SectionRenderer from "./SectionRenderer.astro";
import { buildBookingSections, buildLinkCardSection, buildStructuredSections } from "../lib/sections.js";
import { getBookingConfig } from "../lib/template.js";

const { page, options, locale = "en", profile } = Astro.props;

const copy = locale === "zh"
  ? {
      bookingEyebrow: "预约",
      directEyebrow: "直接联系",
      directHeading: "联系方式",
      directIntro: "如果你更希望先直接联系我，这里是最清楚的入口。",
      optionsHeading: "从这里开始",
      optionsIntro: "如果聊一聊会比来回发消息更有效，这里有一个更完整的预约入口。",
      durationLabel: "形式",
      faqEyebrow: "FAQ",
      faqHeading: "预约前你可能想知道",
      faqIntro: "先把边界和期待说清楚，会让沟通更轻松。",
      bookLabel: "预约一次交流",
      opensCalendly: "将打开 Calendly",
      contactLabels: { email: "邮箱", phone: "电话", linkedin: "LinkedIn" },
    }
  : {
      bookingEyebrow: "Book",
      directEyebrow: "Direct contact",
      directHeading: "Contact details",
      directIntro: "If you would rather reach out first, these are the clearest ways to do it.",
      optionsHeading: "Start here",
      optionsIntro: "If talking is more useful than trading messages, this is the single booking option I use.",
      durationLabel: "Format",
      faqEyebrow: "FAQ",
      faqHeading: "What people often want to know first",
      faqIntro: "Clear expectations make the conversation easier for both sides.",
      bookLabel: "Book a chat",
      opensCalendly: "Opens Calendly",
      contactLabels: { email: "Email", phone: "Phone", linkedin: "LinkedIn" },
    };

const legacyMode = page.showCalendly === true ? "calendly" : "contact-only";
const bookingConfig = getBookingConfig(locale, legacyMode);
const visibleOptions = bookingConfig.mode === "calendly" ? options : [];
const contactDetails = [
  {
    label: copy.contactLabels.email,
    value: profile?.email,
    href: profile?.email ? `mailto:${profile.email}` : undefined,
  },
  {
    label: copy.contactLabels.phone,
    value: profile?.phone,
    href: profile?.phone ? `tel:${profile.phone.replace(/\s+/g, "")}` : undefined,
  },
  {
    label: copy.contactLabels.linkedin,
    value: profile?.linkedin?.replace(/^https?:\/\/(www\.)?/, ""),
    href: profile?.linkedin,
  },
].filter((item) => item.value && item.href);

const [contactSection] = buildLinkCardSection({
  eyebrow: copy.directEyebrow,
  heading: copy.directHeading,
  intro: copy.directIntro,
  items: contactDetails.map((item) => ({
    label: item.label,
    title: item.value,
    summary: "",
    href: item.href,
    external: item.href.startsWith("http"),
    layout: "third",
    actionLabel: locale === "zh" ? "打开" : "Open",
  })),
});

const [detailSection] = buildStructuredSections({
  cards: page.cards ?? [],
  eyebrow: locale === "zh" ? "联系方式" : "Contact options",
  heading: locale === "zh" ? "先确认是否适合联系我" : "A clearer sense of fit",
  intro: "",
});

const bookingSection = visibleOptions.length > 0
  ? {
      type: "booking-options",
      version: 1,
      eyebrow: copy.bookingEyebrow,
      heading: copy.optionsHeading,
      intro: copy.optionsIntro,
      items: visibleOptions.map((option) => ({
        ...option,
        ctaLabel: option.ctaLabel ?? copy.bookLabel,
        opensLabel: copy.opensCalendly,
        label: copy.durationLabel,
      })),
    }
  : null;

const [externalBookingSection] = bookingConfig.mode === "external-link" && bookingConfig.externalUrl
  ? buildLinkCardSection({
      eyebrow: copy.bookingEyebrow,
      heading: copy.optionsHeading,
      intro: copy.optionsIntro,
      items: [{
        label: copy.durationLabel,
        title: bookingConfig.externalLabel ?? copy.bookLabel,
        summary: locale === "zh"
          ? "把这里换成你自己的外部预约或联系入口。只保留一个清楚动作，通常比给出很多弱入口更有效。"
          : "Replace this with your real external booking or contact URL. One clear next step usually works better than several weak ones.",
        href: bookingConfig.externalUrl,
        external: true,
        layout: "half",
        actionLabel: locale === "zh" ? "打开" : "Open",
      }],
    })
  : [];

const faqSection = page.faq?.length > 0
  ? {
      type: "faq",
      version: 1,
      eyebrow: copy.faqEyebrow,
      heading: copy.faqHeading,
      intro: copy.faqIntro,
      items: page.faq,
    }
  : null;

const sections = buildBookingSections({
  contactSection,
  detailSection,
  bookingSection: bookingSection ?? externalBookingSection,
  faqSection,
});
---
<section class="hero-block">
  <p class="eyebrow">{copy.bookingEyebrow}</p>
  <h1 class="hero-title">{page.heroTitle}</h1>
  <p class="hero-copy">{page.heroText}</p>

  {page.ctas?.length > 0 && (
    <div class="cta-row">
      {page.ctas.map((cta) => (
        <a class={cta.variant === "primary" ? "cta" : "ghost-btn"} href={cta.href} target={cta.href.startsWith("http") ? "_blank" : undefined} rel={cta.href.startsWith("http") ? "noreferrer" : undefined}>
          {cta.label}
        </a>
      ))}
    </div>
  )}
</section>

{sections.map((section) => <SectionRenderer section={section} locale={locale} />)}
