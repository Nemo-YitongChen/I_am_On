---
import SectionRenderer from "./SectionRenderer.astro";
import { buildStructuredSections } from "../lib/sections.js";

const { page, locale = "en", eyebrow, sectionTitle, sectionIntro, sections: sectionsProp } = Astro.props;

const isZh = locale === "zh";
const copy = {
  eyebrow: eyebrow ?? (isZh ? "页面概览" : "Overview"),
  sectionTitle: sectionTitle ?? (isZh ? "重点信息" : "Highlights"),
  sectionIntro:
    sectionIntro ??
    (isZh
      ? "用更短、更清楚的方式把这个页面最重要的信息放在前面。"
      : "A faster overview of the most important details on this page."),
};

const sections = sectionsProp ?? buildStructuredSections({
  cards: page.cards ?? [],
  eyebrow: isZh ? "快速浏览" : "At a glance",
  heading: copy.sectionTitle,
  intro: copy.sectionIntro,
});
---
<section class="hero-block">
  <p class="eyebrow">{copy.eyebrow}</p>
  <h1 class="hero-title">{page.heroTitle}</h1>
  <p class="hero-copy">{page.heroText}</p>

  {page.ctas?.length > 0 && (
    <div class="cta-row">
      {page.ctas.map((cta) => (
        <a class={cta.variant === "primary" ? "cta" : "ghost-btn"} href={cta.href}>
          {cta.label}
        </a>
      ))}
    </div>
  )}
</section>

{sections.map((section) => <SectionRenderer section={section} locale={locale} />)}
