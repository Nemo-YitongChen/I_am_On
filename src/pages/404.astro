---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found | I_am_On" description="This page could not be found." locale="en">
  <section class="hero">
    <p class="eyebrow">Not found</p>
    <h1 class="h1" style="max-width:14ch;">This page is not available.</h1>
    <p class="p">
      The link may be old or incomplete. Use the main site routes below to keep exploring the starter.
    </p>
    <div class="cta-row">
      <a class="cta" href="/">Go home</a>
      <a class="ghost-btn" href="/work/">See work</a>
      <a class="ghost-btn" href="/book/">Open book page</a>
    </div>
  </section>
</BaseLayout>
