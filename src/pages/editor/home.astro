---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HomeEditor from "../../components/HomeEditor.astro";
import {
  getDefaultLocale,
  getHomeContentPath,
  getHomePage,
} from "../../lib/site.js";

const locale = getDefaultLocale();
const page = getHomePage(locale);
const contentPath = getHomeContentPath(locale);
---
<BaseLayout title="Editor" description="Edit the default home page content." locale={locale}>
  <HomeEditor page={page} contentPath={contentPath} locale={locale} />
</BaseLayout>
