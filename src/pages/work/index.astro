---
import PageSchemaPage from "../../components/PageSchemaPage.astro";
import { buildLongformListPageSchema } from "../../lib/pageSchemas.js";
import { getDefaultLocale, getLocalePrefix } from "../../lib/site.js";
import { getSlugFromContentId, getWorkList } from "../../lib/content";

const locale = getDefaultLocale();
const isZh = locale === "zh";
const prefix = getLocalePrefix(locale);
const entries = await getWorkList(locale);
const items = entries.map((entry, index) => ({
  href: `${prefix}/work/${getSlugFromContentId(entry.id)}/`,
  title: entry.data.title,
  summary: entry.data.summary,
  meta: `${entry.data.role} · ${entry.data.year}`,
  tags: entry.data.tags,
  layout: index === 0 ? "feature" : "half",
}));

const nextStepCards = [
  {
    href: `${prefix}/recruiters/`,
    label: isZh ? "招聘摘要" : "Recruiters",
    title: isZh ? "把案例进一步对照到岗位匹配" : "Translate proof into role fit",
    summary: isZh ? "如果你已经看过案例，这一页适合更快确认岗位方向和联系入口。" : "Use the recruiter page for a shorter summary of fit, profile context, and contact details.",
    meta: isZh ? "招聘入口" : "Role fit",
    layout: "third",
  },
  {
    href: `${prefix}/book/`,
    label: isZh ? "预约" : "Book",
    title: isZh ? "提供一个直接下一步" : "Offer a direct conversation",
    summary: isZh ? "如果案例已经足够说明问题，这里就是最简单的下一步。" : "If the work already makes the fit clear, this is the simplest next step.",
    meta: isZh ? "直接联系" : "Direct contact",
    layout: "third",
  },
  {
    href: `${prefix}/posts/`,
    label: isZh ? "文章" : "Writing",
    title: isZh ? "再看背后的判断与方法" : "Use writing to explain the work",
    summary: isZh ? "文章能补充案例背后的思路、表达方式和工作方法。" : "The writing is where the reasoning and working style behind the examples can be explained more fully.",
    meta: isZh ? "长文与说明" : "Notes and essays",
    layout: "third",
  },
];

const page = buildLongformListPageSchema({
  locale,
  collection: "work",
  items,
  nextStepCards,
});
---
<PageSchemaPage page={page} locale={locale} />
