---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import LongformEntryPage from "../../components/LongformEntryPage.astro";
import { getDefaultLocale } from "../../lib/site.js";
import { getSlugFromContentId, getWorkList } from "../../lib/content";

export const prerender = true;

export async function getStaticPaths() {
  const locale = getDefaultLocale();
  const entries = await getWorkList(locale);
  return entries.map((entry) => ({
    params: { slug: getSlugFromContentId(entry.id) },
    props: { id: entry.id, locale },
  }));
}

const { id, locale } = Astro.props;
const entry = await getEntry("work", id);

if (!entry) {
  throw new Error(`Missing work entry: ${id}`);
}

const { Content } = await render(entry);
const eyebrow = locale === "zh" ? "案例" : "Work";
const meta = `${entry.data.role} · ${entry.data.year}`;
---
<BaseLayout title={entry.data.title} description={entry.data.description} locale={locale}>
  <LongformEntryPage
    eyebrow={eyebrow}
    title={entry.data.title}
    description={entry.data.description}
    meta={meta}
    tags={entry.data.tags}
    Content={Content}
  />
</BaseLayout>
