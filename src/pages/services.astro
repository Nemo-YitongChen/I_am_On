---
import BaseLayout from "../layouts/BaseLayout.astro";
import StructuredPage from "../components/StructuredPage.astro";
import { getDefaultLocale, getPage } from "../lib/site.js";

const locale = getDefaultLocale();
const page = getPage(locale, "services");
---
<BaseLayout title={page.title} description={page.description} locale={locale}>
  <StructuredPage page={page} locale={locale} />
</BaseLayout>
