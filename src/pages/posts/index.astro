---
import PageSchemaPage from "../../components/PageSchemaPage.astro";
import { buildLongformListPageSchema } from "../../lib/pageSchemas.js";
import { getDefaultLocale, getLocalePrefix } from "../../lib/site.js";
import { getPostsList, getSlugFromContentId } from "../../lib/content";

const locale = getDefaultLocale();
const isZh = locale === "zh";
const prefix = getLocalePrefix(locale);
const entries = await getPostsList(locale);
const items = entries.map((entry, index) => ({
  href: `${prefix}/posts/${getSlugFromContentId(entry.id)}/`,
  title: entry.data.title,
  summary: entry.data.summary,
  meta: entry.data.publishedAt.toISOString().slice(0, 10),
  tags: entry.data.tags,
  layout: index === 0 ? "feature" : "half",
}));

const nextStepCards = [
  {
    href: `${prefix}/work/`,
    label: isZh ? "案例" : "Work",
    title: isZh ? "把文章和实际证明放在一起看" : "Pair the writing with proof",
    summary: isZh ? "案例页更适合展示项目、职责和结果；和文章放在一起看会更完整。" : "The work page shows how the ideas connect to actual projects, roles, and outcomes.",
    meta: isZh ? "证明与案例" : "Proof and examples",
    layout: "third",
  },
  {
    href: `${prefix}/recruiters/`,
    label: isZh ? "招聘摘要" : "Recruiters",
    title: isZh ? "看更简洁的岗位匹配概览" : "See the concise hiring snapshot",
    summary: isZh ? "如果你想更快看背景、角色方向和联系入口，这一页更直接。" : "Use this when you want a shorter fit summary, public profile links, and contact details.",
    meta: isZh ? "招聘入口" : "Role fit",
    layout: "third",
  },
  {
    href: `${prefix}/book/`,
    label: isZh ? "预约" : "Book",
    title: isZh ? "把理解转成下一步交流" : "Turn the context into a conversation",
    summary: isZh ? "如果这些文章已经足够帮助别人形成判断，这里就是最清楚的下一步。" : "If the writing already gives enough context, this is the cleanest next step.",
    meta: isZh ? "直接联系" : "Direct contact",
    layout: "third",
  },
];

const page = buildLongformListPageSchema({
  locale,
  collection: "posts",
  items,
  nextStepCards,
});
---
<PageSchemaPage page={page} locale={locale} />
