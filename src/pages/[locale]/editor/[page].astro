---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HomeEditor from "../../../components/HomeEditor.astro";
import { getEditablePages, getLocaleMeta, getPage, getPageContentPath, getPageLabel, getPublicPath, getSecondaryLocales, isSecondaryLocaleEnabled, editablePageKeys } from "../../../lib/site.js";

export const prerender = true;

export function getStaticPaths() {
  return getSecondaryLocales().flatMap((locale) => editablePageKeys.map((page) => ({ params: { locale, page } })));
}

const locale = Astro.params.locale ?? "";
const pageKey = Astro.params.page ?? "home";
const isValidLocale = isSecondaryLocaleEnabled(locale);
const page = isValidLocale ? getPage(locale, pageKey) : null;

if (!isValidLocale || !page) {
  Astro.response.status = 404;
}
---
<BaseLayout title={isValidLocale ? `Editor · ${getPageLabel(locale, pageKey)}` : "Not found"} description={isValidLocale ? `Edit the ${getPageLabel(locale, pageKey)} page content.` : "Not found."} locale={isValidLocale ? locale : "en"}>
  {isValidLocale && page ? (
    <HomeEditor
      page={page}
      locale={locale}
      localeName={getLocaleMeta(locale).label}
      currentPageKey={pageKey}
      editorLinks={getEditablePages(locale)}
      contentPath={getPageContentPath(locale, pageKey)}
      pagePath={getPublicPath(locale, pageKey)}
      editorTitle={locale === "zh" ? `编辑 ${getPageLabel(locale, pageKey)}` : `Edit ${getPageLabel(locale, pageKey)}`}
      intro={locale === "zh" ? "修改后会写回 GitHub，并在 Cloudflare 重新部署后生效。" : "Edits are written back to GitHub and go live after Cloudflare redeploys the site."}
      saveMessage={locale === "zh" ? `从编辑器更新 ${getPageLabel(locale, pageKey)} 页面` : `Update ${getPageLabel(locale, pageKey)} page from editor`}
    />
  ) : (
    <p class="p">Locale not enabled.</p>
  )}
</BaseLayout>
