---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import HomeEditor from "../../../components/HomeEditor.astro";
import {
  getDefaultLocale,
  getHomeContentPath,
  getHomePage,
  isSecondaryLocaleEnabled,
} from "../../../lib/site.js";

const locale = Astro.params.locale ?? "";
const isValidLocale = isSecondaryLocaleEnabled(locale);

if (!isValidLocale) {
  Astro.response.status = 404;
}

const safeLocale = isValidLocale ? locale : getDefaultLocale();
const page = getHomePage(safeLocale);
const contentPath = getHomeContentPath(safeLocale);
---
<BaseLayout title={isValidLocale ? "Editor" : "Not found"} description={isValidLocale ? "Edit localized home page content." : "Not found."} locale={safeLocale}>
  {isValidLocale ? <HomeEditor page={page} contentPath={contentPath} locale={safeLocale} /> : <p class="p">Locale not enabled.</p>}
</BaseLayout>
