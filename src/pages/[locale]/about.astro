---
import BaseLayout from "../../layouts/BaseLayout.astro";
import StructuredPage from "../../components/StructuredPage.astro";
import { getProfile } from "../../lib/content";
import { getPage, isSecondaryLocaleEnabled } from "../../lib/site.js";
import { getSiteType } from "../../lib/template.js";
import { buildStructuredDataForPage } from "../../lib/structuredData.js";
import { siteConfig } from "../../../site.config.mjs";

const locale = Astro.params.locale ?? "";
const isValidLocale = isSecondaryLocaleEnabled(locale);

if (!isValidLocale) {
  Astro.response.status = 404;
}

const page = isValidLocale ? getPage(locale, "about") : null;
const profile = await getProfile();
const site = Astro.site ?? new URL(siteConfig.site);
const structuredData = isValidLocale && page
  ? buildStructuredDataForPage({
      siteType: getSiteType(),
      pageType: "about",
      profile,
      url: new URL(`/${locale}/about/`, site).toString(),
      title: page.title,
      description: page.description,
      locale,
    })
  : [];
---
<BaseLayout
  title={page?.title ?? "Not found"}
  description={page?.description ?? "Not found."}
  locale={isValidLocale ? locale : "en"}
  structuredData={structuredData}
>
  {isValidLocale && page ? <StructuredPage page={page} locale={locale} /> : <p class="p">Locale not enabled.</p>}
</BaseLayout>
