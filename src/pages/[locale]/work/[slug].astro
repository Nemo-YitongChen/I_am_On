---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageSchemaPage from "../../../components/PageSchemaPage.astro";
import { buildLongformEntryPageSchema } from "../../../lib/pageSchemas.js";
import { getSecondaryLocales, isSecondaryLocaleEnabled } from "../../../lib/site.js";
import { getProfile, getSlugFromContentId, getWorkList } from "../../../lib/content";
import { getSiteType } from "../../../lib/template.js";
import { buildStructuredDataForPage } from "../../../lib/structuredData.js";
import { siteConfig } from "../../../../site.config.mjs";

export const prerender = true;

export async function getStaticPaths() {
  const paths = [];
  for (const locale of getSecondaryLocales()) {
    const entries = await getWorkList(locale);
    paths.push(
      ...entries.map((entry) => ({
        params: { locale, slug: getSlugFromContentId(entry.id) },
        props: { id: entry.id, locale },
      })),
    );
  }
  return paths;
}

const { id, locale } = Astro.props;
const isValidLocale = isSecondaryLocaleEnabled(locale);
const entry = await getEntry("work", id);
const site = Astro.site ?? new URL(siteConfig.site);
const profile = await getProfile();

if (!entry) {
  throw new Error(`Missing work entry: ${id}`);
}

const { Content } = await render(entry);
const meta = `${entry.data.role} · ${entry.data.year}`;
const nextStepCards = [
  {
    href: `/${locale}/recruiters/`,
    label: locale === "zh" ? "招聘摘要" : "Recruiters",
    title: locale === "zh" ? "把这个案例对照到岗位匹配" : "Translate this case into role fit",
    summary: locale === "zh" ? "适合把单个案例进一步放进更简洁的招聘语境里。" : "Use the recruiter page for the shortest hiring summary and contact context.",
    meta: locale === "zh" ? "招聘入口" : "Role fit",
    layout: "third",
  },
  {
    href: `/${locale}/work/`,
    label: locale === "zh" ? "案例" : "Work",
    title: locale === "zh" ? "继续浏览更多案例" : "Browse more case studies",
    summary: locale === "zh" ? "回到案例页，可以更完整地看不同职责、项目和证明类型。" : "Go back to the work page for a broader view across roles, environments, and examples.",
    meta: locale === "zh" ? "更多证明" : "More proof",
    layout: "third",
  },
  {
    href: `/${locale}/book/`,
    label: locale === "zh" ? "预约" : "Book",
    title: locale === "zh" ? "如果已经判断得差不多" : "Offer a direct next step",
    summary: locale === "zh" ? "如果这个案例已经说明了大部分问题，这里就是最简单的下一步。" : "If this case already tells the story, this is the simplest next step.",
    meta: locale === "zh" ? "直接联系" : "Direct contact",
    layout: "third",
  },
];
const page = buildLongformEntryPageSchema({
  locale,
  collection: "work",
  entry,
  meta,
  leadTitle: locale === "zh" ? "案例摘要" : "Case summary",
  leadText: entry.data.summary,
  nextStepCards,
  Content,
});
const structuredData = buildStructuredDataForPage({
  siteType: getSiteType(),
  pageType: "work",
  profile,
  url: new URL(`/${locale}/work/${getSlugFromContentId(entry.id)}/`, site).toString(),
  title: entry.data.title,
  description: entry.data.description,
  locale,
});
---
{isValidLocale ? (
  <PageSchemaPage page={page} locale={locale} structuredData={structuredData} />
) : (
  <BaseLayout title="Not found | Your Name" description="Locale not enabled." locale="en">
    <p class="p">Locale not enabled.</p>
  </BaseLayout>
)}
