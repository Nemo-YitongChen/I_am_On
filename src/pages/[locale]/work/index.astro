---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageSchemaPage from "../../../components/PageSchemaPage.astro";
import { buildLongformListPageSchema } from "../../../lib/pageSchemas.js";
import { isSecondaryLocaleEnabled } from "../../../lib/site.js";
import { getSlugFromContentId, getWorkList } from "../../../lib/content";

const locale = Astro.params.locale ?? "";
const isValidLocale = isSecondaryLocaleEnabled(locale);

if (!isValidLocale) {
  Astro.response.status = 404;
}

const entries = isValidLocale ? await getWorkList(locale) : [];
const items = entries.map((entry, index) => ({
  href: `/${locale}/work/${getSlugFromContentId(entry.id)}/`,
  title: entry.data.title,
  summary: entry.data.summary,
  meta: `${entry.data.role} · ${entry.data.year}`,
  tags: entry.data.tags,
  layout: index === 0 ? "feature" : "half",
}));

const nextStepCards = [
  {
    href: `/${locale}/recruiters/`,
    label: locale === "zh" ? "招聘摘要" : "Recruiters",
    title: locale === "zh" ? "把案例进一步对照到岗位匹配" : "Translate proof into role fit",
    summary: locale === "zh" ? "如果你已经看过案例，这一页适合更快确认岗位方向和联系入口。" : "Use the recruiter page for a shorter summary of fit, profile context, and contact details.",
    meta: locale === "zh" ? "招聘入口" : "Role fit",
    layout: "third",
  },
  {
    href: `/${locale}/book/`,
    label: locale === "zh" ? "预约" : "Book",
    title: locale === "zh" ? "提供一个直接下一步" : "Offer a direct conversation",
    summary: locale === "zh" ? "如果案例已经足够说明问题，这里就是最简单的下一步。" : "If the work already makes the fit clear, this is the simplest next step.",
    meta: locale === "zh" ? "直接联系" : "Direct contact",
    layout: "third",
  },
  {
    href: `/${locale}/posts/`,
    label: locale === "zh" ? "文章" : "Writing",
    title: locale === "zh" ? "再看背后的判断与方法" : "Use writing to explain the work",
    summary: locale === "zh" ? "文章能补充案例背后的思路、表达方式和工作方法。" : "The writing is where the reasoning and working style behind the examples can be explained more fully.",
    meta: locale === "zh" ? "长文与说明" : "Notes and essays",
    layout: "third",
  },
];

const page = isValidLocale
  ? buildLongformListPageSchema({
      locale,
      collection: "work",
      items,
      nextStepCards,
    })
  : null;
---
{isValidLocale ? (
  <PageSchemaPage page={page} locale={locale} />
) : (
  <BaseLayout
    title="Not found | Your Name"
    description="Locale not enabled."
    locale="en"
  >
    <p class="p">Locale not enabled.</p>
  </BaseLayout>
)}
