---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageSchemaPage from "../../../components/PageSchemaPage.astro";
import { buildLongformListPageSchema } from "../../../lib/pageSchemas.js";
import { isSecondaryLocaleEnabled } from "../../../lib/site.js";
import { getPostsList, getSlugFromContentId } from "../../../lib/content";

const locale = Astro.params.locale ?? "";
const isValidLocale = isSecondaryLocaleEnabled(locale);

if (!isValidLocale) {
  Astro.response.status = 404;
}

const entries = isValidLocale ? await getPostsList(locale) : [];
const items = entries.map((entry, index) => ({
  href: `/${locale}/posts/${getSlugFromContentId(entry.id)}/`,
  title: entry.data.title,
  summary: entry.data.summary,
  meta: entry.data.publishedAt.toISOString().slice(0, 10),
  tags: entry.data.tags,
  layout: index === 0 ? "feature" : "half",
}));

const nextStepCards = [
  {
    href: `/${locale}/work/`,
    label: locale === "zh" ? "案例" : "Work",
    title: locale === "zh" ? "把文章和实际证明放在一起看" : "Pair the writing with proof",
    summary: locale === "zh" ? "案例页更适合展示项目、职责和结果；和文章放在一起看会更完整。" : "The work page shows how the ideas connect to actual projects, roles, and outcomes.",
    meta: locale === "zh" ? "证明与案例" : "Proof and examples",
    layout: "third",
  },
  {
    href: `/${locale}/recruiters/`,
    label: locale === "zh" ? "招聘摘要" : "Recruiters",
    title: locale === "zh" ? "看更简洁的岗位匹配概览" : "See the concise hiring snapshot",
    summary: locale === "zh" ? "如果你想更快看背景、角色方向和联系入口，这一页更直接。" : "Use this when you want a shorter fit summary, public profile links, and contact details.",
    meta: locale === "zh" ? "招聘入口" : "Role fit",
    layout: "third",
  },
  {
    href: `/${locale}/book/`,
    label: locale === "zh" ? "预约" : "Book",
    title: locale === "zh" ? "把理解转成下一步交流" : "Turn the context into a conversation",
    summary: locale === "zh" ? "如果这些文章已经足够帮助别人形成判断，这里就是最清楚的下一步。" : "If the writing already gives enough context, this is the cleanest next step.",
    meta: locale === "zh" ? "直接联系" : "Direct contact",
    layout: "third",
  },
];

const page = isValidLocale
  ? buildLongformListPageSchema({
      locale,
      collection: "posts",
      items,
      nextStepCards,
    })
  : null;
---
{isValidLocale ? (
  <PageSchemaPage page={page} locale={locale} />
) : (
  <BaseLayout
    title="Not found | Your Name"
    description="Locale not enabled."
    locale="en"
  >
    <p class="p">Locale not enabled.</p>
  </BaseLayout>
)}
