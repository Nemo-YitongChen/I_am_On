---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PageSchemaPage from "../../../components/PageSchemaPage.astro";
import { buildLongformEntryPageSchema } from "../../../lib/pageSchemas.js";
import { getSecondaryLocales, isSecondaryLocaleEnabled } from "../../../lib/site.js";
import { getPostsList, getProfile, getSlugFromContentId } from "../../../lib/content";
import { getSiteType } from "../../../lib/template.js";
import { buildStructuredDataForPage } from "../../../lib/structuredData.js";
import { siteConfig } from "../../../../site.config.mjs";

export const prerender = true;

export async function getStaticPaths() {
  const paths = [];
  for (const locale of getSecondaryLocales()) {
    const entries = await getPostsList(locale);
    paths.push(
      ...entries.map((entry) => ({
        params: { locale, slug: getSlugFromContentId(entry.id) },
        props: { id: entry.id, locale },
      })),
    );
  }
  return paths;
}

const { id, locale } = Astro.props;
const isValidLocale = isSecondaryLocaleEnabled(locale);
const entry = await getEntry("posts", id);
const site = Astro.site ?? new URL(siteConfig.site);
const profile = await getProfile();

if (!entry) {
  throw new Error(`Missing post entry: ${id}`);
}

const { Content } = await render(entry);
const meta = entry.data.publishedAt.toISOString().slice(0, 10);
const nextStepCards = [
  {
    href: `/${locale}/work/`,
    label: locale === "zh" ? "案例" : "Work",
    title: locale === "zh" ? "把文章放回到真实证明里看" : "Connect the writing to proof",
    summary: locale === "zh" ? "案例页会把这些想法对应到具体项目、职责与结果上。" : "The work page shows how the ideas relate to actual roles, projects, and outcomes.",
    meta: locale === "zh" ? "证明与案例" : "Proof and examples",
    layout: "third",
  },
  {
    href: `/${locale}/recruiters/`,
    label: locale === "zh" ? "招聘摘要" : "Recruiters",
    title: locale === "zh" ? "看更简洁的岗位匹配概览" : "See the concise hiring snapshot",
    summary: locale === "zh" ? "如果你想更快看背景、角色方向和联系入口，这一页更直接。" : "Use this for the shortest route into fit summary, profile links, and contact details.",
    meta: locale === "zh" ? "招聘入口" : "Role fit",
    layout: "third",
  },
  {
    href: `/${locale}/book/`,
    label: locale === "zh" ? "预约" : "Book",
    title: locale === "zh" ? "把理解转成下一步交流" : "Turn the context into a conversation",
    summary: locale === "zh" ? "如果这篇文章已经足够帮助别人形成判断，这里就是最清楚的下一步。" : "If the post already gives enough context, this is the cleanest next step.",
    meta: locale === "zh" ? "直接联系" : "Direct contact",
    layout: "third",
  },
];
const page = buildLongformEntryPageSchema({
  locale,
  collection: "posts",
  entry,
  meta,
  leadTitle: locale === "zh" ? "核心观点" : "Key idea",
  leadText: entry.data.summary,
  nextStepCards,
  Content,
});
const structuredData = buildStructuredDataForPage({
  siteType: getSiteType(),
  pageType: "post",
  profile,
  url: new URL(`/${locale}/posts/${getSlugFromContentId(entry.id)}/`, site).toString(),
  title: entry.data.title,
  description: entry.data.description,
  locale,
  publishedAt: entry.data.publishedAt,
});
---
{isValidLocale ? (
  <PageSchemaPage page={page} locale={locale} structuredData={structuredData} />
) : (
  <BaseLayout title="Not found | Your Name" description="Locale not enabled." locale="en">
    <p class="p">Locale not enabled.</p>
  </BaseLayout>
)}
